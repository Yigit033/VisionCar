# EV ihlal backend — yapılandırma şablonu.
# Bu dosyayı `.env` olarak kopyalayın. .env .gitignore'dadır — SIRLAR repoya GİRMEZ.

# ---- Kamera (ISAPI pull) ----
# camera_mode: isapi (gerçek kamera) | mock (kamerasız test, sentetik görsel)
CAMERA_MODE=isapi
CAMERA_IP=192.168.137.1
CAMERA_USER=admin
CAMERA_PASSWORD=şifre            # SADECE buraya/ortam değişkenine; koda yazma
CAMERA_CHANNEL=101
CAMERA_TIMEOUT_SEC=5

# ---- Kurallar / orkestrasyon (oturum modeli) ----
# İşgal olayından sonra ihlal kararına kadarki bekleme (gerçekte 60-120 sn).
# Faz 1 demosunda kısa tutun (ör. 10).
GRACE_PERIOD_SEC=10
# Hedef bu kadar süre geri dönmezse "oturum" kapanır (yer boşaldı sayılır).
# Kısa VCA titremelerinin oturumu kapatmaması için birkaç saniye verin.
VACANCY_GRACE_SEC=15
# Süregelen ihlal için re-kanıt aralığı. 0 = oturum başına TEK olay (önerilen).
# >0 verirsen (ör. 300) araç durduğu sürece bu aralıkla yeni kanıt üretir.
REPEAT_NOTIFY_SEC=0
# Bu durumlar İHLAL SAYILMAZ (virgülle). Geri kalan her durum ihlaldir.
NON_VIOLATION_STATUSES=CHARGING,PREPARING

# ---- Telemetri (Faz 1 mock) ----
# Mock'un varsayılan döndüreceği durum. Demo için NOT_CHARGING bırakın.
TELEMETRY_DEFAULT_STATUS=NOT_CHARGING

# ---- Saklama / forward / retention ----
FORWARD_INTERVAL_SEC=10
FORWARD_MAX_RETRIES=5
# KVKK: araç görüntüsü kişisel veridir. Şu günden eski görseller otomatik silinir.
RETENTION_DAYS=30
RETENTION_INTERVAL_SEC=3600

# ---- Sunucu ----
HOST=127.0.0.1
PORT=8090
